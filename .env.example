# Copy this file to .env.local and fill in your Upstash credentials
# Get these from your Upstash dashboard → your Redis database → REST API section

UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Optional: Set a secret token to secure your webhook endpoints
# Generate any random string e.g. "mysecret123"
WEBHOOK_SECRET=your_webhook_secret_here
